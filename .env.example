# Copy to .env and fill in. NEVER commit real values.
# --- Tier 1: Travelpayouts / Aviasales Data API (free, cached) ---
TP_TOKEN=
TP_MARKER=                # optional affiliate marker for deep links

# --- Tier 2: Duffel (paid, live mode). Double-gated — see runner/config. ---
DUFFEL_API_KEY=           # live key (duffel_live_...) — billed
DUFFEL_TEST_API_KEY=      # test key (duffel_test_...) — used by --dry-run
DUFFEL_ENABLE_LIVE=       # must be "1" AND config duffel.live_confirmed:true to charge

# --- Alerting ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- SMTP fallback (stub) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# --- Optional: seats.aero Pro award module ---
SEATS_AERO_API_KEY=
